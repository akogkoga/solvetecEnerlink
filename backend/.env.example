# === Motor de Leads B2B — Variáveis de Ambiente ===

# Casa dos Dados v5 (discovery principal)
# Cadastro: https://portal.casadosdados.com.br/cadastro
CASADOSDADOS_API_KEY=

# Redis (opcional — fallback para cache em memória)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# SQLite local ou disco persistente no Render
SQLITE_DB_PATH=data/empresas.db

# Use apenas se frontend e backend estiverem em dominios separados
CORS_ORIGINS=

# Cloudscraper (bypass Cloudflare)
USE_CLOUDSCRAPER=true

# Configurações de request
DEFAULT_TIMEOUT=15
MAX_RETRIES=2
CACHE_TTL_SECONDS=1800
MAX_ENRICHMENT_CONCURRENT=3
MAX_ENRICHMENT_LEADS=6
ENRICHMENT_MODE=balanced
